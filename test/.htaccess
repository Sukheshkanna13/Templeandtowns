# Serve .jsx files with the correct JavaScript MIME type
# Required for Babel standalone to transpile .jsx scripts in the browser
AddType application/javascript .jsx
AddType text/javascript .jsx

# Serve .js files correctly (redundant but explicit for safety)
AddType application/javascript .js

# Ensure correct charset
AddDefaultCharset UTF-8

# Enable gzip compression for better performance
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# Prevent caching issues during development
<IfModule mod_headers.c>
  <FilesMatch "\.(jsx|js|css|html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
